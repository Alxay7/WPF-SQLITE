<Window x:Class="WPF_SQLITE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_SQLITE"
        mc:Ignorable="d"
        Title="Sqlite" Height="500" Width="800">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
            <TextBlock Text="Imię" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBox x:Name="ImieTextBox" Height="30" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

            <TextBlock Text="Nazwisko" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBox x:Name="NazwiskoTextBox" Height="30" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

            <TextBlock Text="PESEL" Margin="0,0,0,4" FontWeight="SemiBold"/>
            <TextBox x:Name="PeselTextBox" Height="30" MaxLength="11" VerticalContentAlignment="Center"/>

            <Button x:Name="addButton" Content="Dodaj" Height="30" Margin="0,12,0,0" Click="addButton_Click"/>
        </StackPanel>


        <DataGrid Grid.Column="1"
                  x:Name="OsobyDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Imię" Binding="{Binding Imie}" Width="*"/>
                <DataGridTextColumn Header="Nazwisko" Binding="{Binding Nazwisko}" Width="*"/>
                <DataGridTextColumn Header="PESEL" Binding="{Binding Pesel}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
